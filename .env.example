# Database
# DATABASE_URL: runtime connection. On Supabase use the pooled URL (port 6543).
DATABASE_URL=postgres://postgres:postgres@localhost:5432/sabor_financeiro
# DIRECT_URL: direct session-mode connection (port 5432). REQUIRED for migrations.

# Public app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Session
SESSION_COOKIE_SECRET=change-me-to-a-long-random-string-min-32-chars

# OAuth Google
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Email
# Sender addresses are hardcoded per purpose in src/infrastructure/email/senders.ts
# (auth -> nao-responda@saborfinanceiro.com.br). Verify the domain in Resend.
RESEND_API_KEY=
# Webhook secret do Resend (Standard Webhooks / Svix). Obter no dashboard do
# Resend ao registrar o endpoint /api/webhooks/resend. Formato: whsec_...
RESEND_WEBHOOK_SECRET=

# Rate limit (placeholder until Plan 2)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Observability (optional)
SENTRY_DSN=

# SEO / Search Console
# Token de verificação do Google Search Console (apenas o token, sem a tag <meta>).
# Crie em https://search.google.com/search-console -> Adicionar propriedade -> HTML tag.
GOOGLE_SITE_VERIFICATION=

# Token de verificação do Bing Webmaster Tools.
# Crie em https://www.bing.com/webmasters -> Add a site -> Meta tag.
BING_SITE_VERIFICATION=

# Token de verificação do Yandex Webmaster (opcional, mercado russo).
# Crie em https://webmaster.yandex.com -> Add site -> Meta tag.
YANDEX_SITE_VERIFICATION=

# Web Push (PWA notifications)
# Gere com: pnpm vapid:generate
# Public key precisa estar exposta no client (NEXT_PUBLIC_*).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# Email ou URL de contato para identificar o remetente para push services.
VAPID_SUBJECT=mailto:nao-responda@saborfinanceiro.com.br

# Cotação de ações (brapi.dev). Opcional: sem token, a atualização de cotações fica indisponível.
# Crie um token gratuito em https://brapi.dev
BRAPI_TOKEN=

# Segredo usado pelo cron diário de atualização de cotações (Vercel Cron).
# Defina um valor longo e aleatório; o cron passa esse valor para autenticar a chamada.
CRON_SECRET=

# ---- Stripe billing -------------------------------------------------------
# Server-only. Chaves obtidas no Stripe Dashboard.
STRIPE_SECRET_KEY=
# Reservado para futuro Stripe Elements (não usado no MVP).
STRIPE_PUBLISHABLE_KEY=
# Webhook signing secret (whsec_...). Obtido ao criar endpoint no Dashboard.
STRIPE_WEBHOOK_SECRET=
# Price ID do plano Pro mensal (price_...). Criado manualmente no Dashboard.
STRIPE_PRICE_ID_PRO_MONTHLY=
# Valor display em centavos (UI). 1490 = R$ 14,90.
NEXT_PUBLIC_PRO_PRICE_CENTS=1490

# Admin step-up TOTP encryption key (32 random bytes, base64). Generate:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ADMIN_TOTP_ENC_KEY=

# ---- PostHog (product analytics) ------------------------------------------
# Project API key (phc_...) do projeto no PostHog. Público (client-side).
NEXT_PUBLIC_POSTHOG_KEY=
# Host de ingestão. Use o reverse proxy local "/ingest" (definido em
# next.config rewrites -> us.i.posthog.com) para driblar adblock e CSP.
NEXT_PUBLIC_POSTHOG_HOST=/ingest
