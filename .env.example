# ============================================================================
# Sabor Financeiro - template de variáveis de ambiente
# Copie para .env.local e preencha. Vars sem valor abaixo são opcionais ou
# só fazem sentido em produção (Vercel). Mantenha esta ordem em .env.local.
# ============================================================================

# ---- Core (obrigatórias) ---------------------------------------------------
# Em Supabase use a URL do pooler (porta 6543). Migrations precisam da conexão
# direta (porta 5432) - rode com DIRECT_URL apontando pro host db.<ref>.
DATABASE_URL=postgresql://USER:PASS@HOST:6543/postgres
NEXT_PUBLIC_APP_URL=http://localhost:3000
# 64 bytes hex. Gerar: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_COOKIE_SECRET=

# ---- Auth (Google OAuth) ---------------------------------------------------
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ---- Email (Resend) --------------------------------------------------------
RESEND_API_KEY=
# Assina os webhooks de status de entrega (bounce/complaint).
RESEND_WEBHOOK_SECRET=

# ---- Cache / rate-limit (Upstash Redis) ------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---- Fila async de webhooks (QStash) ---------------------------------------
# Prod only. Em dev, deixe vazio = processa inline (mesmo path do Stripe CLI).
# Console: https://console.upstash.com/qstash (mesma conta do Redis).
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# ---- Billing (Stripe) ------------------------------------------------------
# Use chaves de TEST em dev (sk_test/pk_test). Price IDs ficam no DB (tabela
# plans via scripts/seed-pro-plan), NÃO em env.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Comma-separated. Default "card". Trocar para "card,pix" só após habilitar PIX
# na conta Stripe (Dashboard -> Settings -> Payment methods).
STRIPE_PAYMENT_METHODS=card

# ---- Storage de anexos (Cloudflare R2) -------------------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET=
R2_BUCKET=

# ---- Storage público (Supabase) --------------------------------------------
# Base URL do projeto Supabase. Monta links públicos do Storage (áudio das trilhas).
NEXT_PUBLIC_SUPABASE_URL=

# ---- Push (Web Push / VAPID) -----------------------------------------------
# Gerar par: pnpm dlx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_SUBJECT=mailto:nao-responda@saborfinanceiro.com.br

# ---- Admin step-up (TOTP) --------------------------------------------------
# 32 bytes, base64. Gerar: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ADMIN_TOTP_ENC_KEY=

# ---- Cron (cotações diárias) -----------------------------------------------
# Segredo que protege as rotas de cron (atualização de cotações).
CRON_SECRET=

# ---- Cotação de câmbio (FX) ------------------------------------------------
# Opcional: endpoint da API de câmbio. Sem isso, a conversão usa o fallback.
EXCHANGE_RATE_API_URL=

# ---- Analytics (PostHog) ---------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=
# Reverse proxy local (next.config rewrites -> us.i.posthog.com) p/ driblar adblock.
NEXT_PUBLIC_POSTHOG_HOST=/ingest

# ---- Analytics (Plausible) -------------------------------------------------
PLAUSIBLE_DOMAIN=

# ---- Monitoring (Sentry) ---------------------------------------------------
SENTRY_DSN=

# ---- SEO verification (opcionais) ------------------------------------------
GOOGLE_SITE_VERIFICATION=
BING_SITE_VERIFICATION=
YANDEX_SITE_VERIFICATION=

# ---- TWA / Android (PWABuilder) --------------------------------------------
# Digital Asset Links: vincula o app Android ao domínio p/ a TWA abrir sem a
# barra de URL. Fingerprint SHA-256 sai do keystore que o PWABuilder gera;
# preencher após o primeiro empacotamento. Vários separados por vírgula.
ANDROID_PACKAGE_NAME=br.com.saborfinanceiro.twa
ANDROID_CERT_SHA256=
