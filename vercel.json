{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "git": {
    "deploymentEnabled": {
      "master": false
    }
  },
  "buildCommand": "pnpm build",
  "installCommand": "pnpm install --frozen-lockfile",
  "devCommand": "pnpm dev",
  "regions": ["gru1"],
  "crons": [
    {
      "path": "/api/cron/push-notifications",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/jobs/usage-purge",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/retention-purge",
      "schedule": "0 3 * * *"
    }
  ]
}
